      "title": { "en": "Playlist", "de": "Playlist" },
      "placeholder": { "en": "Homey Watchlist", "de": "Homey Watchlist" }
    }
  ],
  "tokens": [
    { "name": "title", "type": "string", "title": { "en": "Title", "de": "Titel" } }
  ]
}
