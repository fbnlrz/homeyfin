{
  "id": "com.frlrnzn.homeyfin",
  "version": "0.1.0",
  "compatibility": ">=12.1.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Homeyfin",
    "de": "Homeyfin"
  },
  "description": {
    "en": "Control your Jellyfin server and clients from Homey.",
    "de": "Steuere deinen Jellyfin-Server und -Clients aus Homey."
  },
  "category": [
    "video"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "frlrnzn",
    "email": "frlrnzn@gmail.com"
  },
  "brandColor": "#00A4DC",
  "source": "https://github.com/fbnlrz/homeyfin",
  "tags": {
    "en": [
      "jellyfin",
      "media",
      "video",
      "movies"
    ],
    "de": [
      "jellyfin",
      "medien",
      "video",
      "filme"
    ]
  },
  "api": {
    "getServers": {
      "method": "GET",
      "path": "/widget/servers"
    },
    "getOverview": {
      "method": "GET",
      "path": "/widget/overview"
    },
    "getNowPlaying": {
      "method": "GET",
      "path": "/widget/now_playing"
    },
    "togglePlayback": {
      "method": "POST",
      "path": "/widget/playback/toggle"
    }
  },
  "capabilities": {
    "client_online": {
      "type": "boolean",
      "title": {
        "en": "Client online",
        "de": "Client online"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "last_added_title": {
      "type": "string",
      "title": {
        "en": "Last added",
        "de": "Zuletzt hinzugefügt"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "library_episodes_count": {
      "type": "number",
      "title": {
        "en": "Episodes",
        "de": "Folgen"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "library_movies_count": {
      "type": "number",
      "title": {
        "en": "Movies",
        "de": "Filme"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "library_series_count": {
      "type": "number",
      "title": {
        "en": "Series",
        "de": "Serien"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_duration": {
      "type": "number",
      "title": {
        "en": "Duration",
        "de": "Dauer"
      },
      "units": {
        "en": "s"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_position": {
      "type": "number",
      "title": {
        "en": "Position",
        "de": "Position"
      },
      "units": {
        "en": "s"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_subtitle": {
      "type": "string",
      "title": {
        "en": "Subtitle",
        "de": "Untertitel"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "media_title": {
      "type": "string",
      "title": {
        "en": "Now playing",
        "de": "Läuft gerade"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "scan_in_progress": {
      "type": "boolean",
      "title": {
        "en": "Library scan running",
        "de": "Bibliotheks-Scan läuft"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "library_scan_finished",
        "title": {
          "en": "Library scan finished",
          "de": "Bibliotheks-Scan abgeschlossen"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "tokens": [
          {
            "name": "duration_seconds",
            "type": "number",
            "title": {
              "en": "Duration (s)",
              "de": "Dauer (s)"
            }
          }
        ]
      },
      {
        "id": "new_item_added",
        "title": {
          "en": "New item added to library",
          "de": "Neuer Inhalt zur Bibliothek hinzugefügt"
