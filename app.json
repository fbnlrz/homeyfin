          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=client"
          }
        ]
      },
      {
        "id": "media_type_is",
        "title": {
          "en": "Media type !{{is|is not}}",
          "de": "Medientyp !{{ist|ist nicht}}"
        },
        "titleFormatted": {
