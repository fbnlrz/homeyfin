  "drivers": [
    {
      "name": {
        "en": "Jellyfin Client",
        "de": "Jellyfin-Client"
      },
      "class": "tv",
      "capabilities": [
        "speaker_playing",
        "speaker_next",
        "speaker_prev",
        "speaker_track",
        "speaker_artist",
        "speaker_album",
        "volume_set",
        "volume_mute",
        "media_title",
        "media_subtitle",
        "media_position",
        "media_duration",
        "client_online"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/client/assets/images/small.png",
        "large": "/drivers/client/assets/images/large.png",
        "xlarge": "/drivers/client/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "select_server"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Behavior",
            "de": "Verhalten"
          },
          "children": [
            {
              "id": "stoppedDebounceMs",
              "type": "number",
              "label": {
                "en": "Stop debounce (ms)",
                "de": "Stop-Entprellzeit (ms)"
              },
              "hint": {
                "en": "Wait this long after a session disappears before firing the Stopped trigger. Helps with brief network blips.",
                "de": "So lange warten, nachdem eine Session verschwindet, bevor der Stop-Trigger feuert. Hilft gegen kurze Netzwerkaussetzer."
              },
              "value": 4000,
              "min": 0,
              "max": 30000
            }
          ]
        }
      ],
      "id": "client"
    },
    {
      "name": {
        "en": "Jellyfin Server",
        "de": "Jellyfin-Server"
      },
      "class": "other",
      "capabilities": [
        "library_movies_count",
        "library_series_count",
        "library_episodes_count",
        "last_added_title",
        "scan_in_progress"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/server/assets/images/small.png",
        "large": "/drivers/server/assets/images/large.png",
        "xlarge": "/drivers/server/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "credentials"
        }
      ],
      "repair": [
        {
          "id": "credentials"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Connection",
            "de": "Verbindung"
          },
          "children": [
            {
              "id": "baseUrl",
              "type": "text",
              "label": {
                "en": "Server URL",
                "de": "Server-URL"
              },
              "hint": {
                "en": "e.g. http://192.168.1.10:8096",
                "de": "z. B. http://192.168.1.10:8096"
              },
              "value": ""
            },
            {
              "id": "apiKey",
              "type": "password",
              "label": {
                "en": "API Key",
                "de": "API-Schlüssel"
              },
              "value": ""
            },
            {
              "id": "userName",
              "type": "text",
              "label": {
                "en": "Default user",
                "de": "Standard-Benutzer"
              },
              "hint": {
                "en": "User whose latest items / counts are reported.",
                "de": "Benutzer, dessen 'Zuletzt hinzugefügt' und Counts angezeigt werden."
              },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Polling",
            "de": "Polling"
          },
          "children": [
            {
              "id": "libraryPollMinutes",
              "type": "number",
              "label": {
                "en": "Library refresh (min)",
                "de": "Bibliotheks-Refresh (min)"
              },
              "value": 5,
              "min": 1,
              "max": 120
            },
            {
              "id": "fallbackPollSeconds",
              "type": "number",
              "label": {
                "en": "Session fallback poll (s)",
                "de": "Session-Fallback-Polling (s)"
              },
              "hint": {
                "en": "How often to poll /Sessions when the WebSocket is disconnected.",
                "de": "Wie oft /Sessions abgefragt werden, wenn die WebSocket-Verbindung weg ist."
              },
              "value": 30,
              "min": 5,
              "max": 300
            }
          ]
        }
      ],
      "id": "server"
    }
  ],
  "widgets": {
    "now_playing": {
      "name": {
        "en": "Now playing",
