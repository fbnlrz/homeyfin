{
  "id": "com.frlrnzn.homeyfin",
  "version": "0.1.0",
  "compatibility": ">=12.1.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Homeyfin",
    "de": "Homeyfin"
  },
  "description": {
    "en": "Control your Jellyfin server and clients from Homey.",
    "de": "Steuere deinen Jellyfin-Server und -Clients aus Homey."
  },
  "category": [
    "video"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "frlrnzn",
    "email": "frlrnzn@gmail.com"
  },
  "brandColor": "#00A4DC",
  "source": "https://github.com/fbnlrz/homeyfin",
  "tags": {
    "en": [
      "jellyfin",
      "media",
      "video",
      "movies"
    ],
    "de": [
      "jellyfin",
      "medien",
      "video",
      "filme"
    ]
  },
  "capabilities": {
    "client_online": {
      "type": "boolean",
      "title": {
        "en": "Client online",
        "de": "Client online"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "continue_watching_title": {
      "type": "string",
      "title": {
        "en": "Up next",
        "de": "Als Nächstes"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "is_transcoding": {
      "type": "boolean",
      "title": {
        "en": "Transcoding",
        "de": "Transcodiert"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "last_added_title": {
      "type": "string",
      "title": {
        "en": "Last added",
        "de": "Zuletzt hinzugefügt"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "library_episodes_count": {
      "type": "number",
      "title": {
        "en": "Episodes",
        "de": "Folgen"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "library_movies_count": {
      "type": "number",
      "title": {
        "en": "Movies",
        "de": "Filme"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "library_series_count": {
      "type": "number",
      "title": {
        "en": "Series",
        "de": "Serien"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_duration": {
      "type": "number",
      "title": {
        "en": "Duration",
        "de": "Dauer"
      },
      "units": {
        "en": "s"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_position": {
      "type": "number",
      "title": {
        "en": "Position",
        "de": "Position"
      },
      "units": {
        "en": "s"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "media_subtitle": {
      "type": "string",
      "title": {
        "en": "Subtitle",
        "de": "Untertitel"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "media_title": {
      "type": "string",
      "title": {
        "en": "Now playing",
        "de": "Läuft gerade"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "scan_in_progress": {
      "type": "boolean",
      "title": {
        "en": "Library scan running",
        "de": "Bibliotheks-Scan läuft"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "socket_online": {
      "type": "boolean",
      "title": {
        "en": "Server connected",
        "de": "Server verbunden"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor"
    },
    "stream_count": {
      "type": "number",
      "title": {
        "en": "Active streams",
        "de": "Aktive Streams"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "transcoding_count": {
      "type": "number",
      "title": {
        "en": "Transcoding streams",
        "de": "Transcodierende Streams"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    },
    "unwatched_count": {
      "type": "number",
      "title": {
        "en": "Unwatched episodes",
        "de": "Ungesehene Folgen"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "library_scan_finished",
        "title": {
          "en": "Library scan finished",
          "de": "Bibliotheks-Scan abgeschlossen"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          }
        ],
        "tokens": [
          {
            "name": "duration_seconds",
            "type": "number",
            "title": {
              "en": "Duration (s)",
              "de": "Dauer (s)"
            }
          }
        ]
      },
      {
        "id": "minutes_before_end",
        "title": {
          "en": "Minutes before end",
          "de": "Minuten vor Ende"
        },
        "hint": {
          "en": "Fires once per item when the remaining time crosses the threshold.",
          "de": "Wird einmal pro Item ausgelöst, wenn die verbleibende Zeit den Schwellwert unterschreitet."
        },
        "titleFormatted": {
          "en": "[[minutes]] minutes before end",
          "de": "[[minutes]] Minuten vor Ende"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=user"
          },
          {
            "name": "minutes",
            "type": "number",
            "title": {
              "en": "Minutes",
              "de": "Minuten"
            },
            "min": 1,
            "max": 60,
            "step": 1,
            "placeholder": {
              "en": "5"
            }
          }
        ],
        "tokens": [
          {
            "name": "title",
            "type": "string",
            "title": {
              "en": "Title",
              "de": "Titel"
            }
          },
          {
            "name": "type",
            "type": "string",
            "title": {
              "en": "Type",
              "de": "Typ"
            }
          },
          {
            "name": "series",
            "type": "string",
            "title": {
              "en": "Series",
              "de": "Serie"
            }
          },
          {
            "name": "remaining_seconds",
            "type": "number",
            "title": {
              "en": "Remaining (s)",
              "de": "Restzeit (s)"
            }
          }
        ]
      },
      {
        "id": "new_item_added",
        "title": {
          "en": "New item added to library",
          "de": "Neuer Inhalt zur Bibliothek hinzugefügt"
        },
        "titleFormatted": {
          "en": "New [[item_type]] in [[library]]",
          "de": "Neuer Inhalt ([[item_type]]) in [[library]]"
        },
        "hint": {
          "en": "Triggers when a new movie, episode or series is added.",
          "de": "Wird ausgelöst, wenn ein neuer Film, Folge oder Serie hinzugefügt wird."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=server"
          },
          {
            "name": "item_type",
            "type": "dropdown",
            "title": {
              "en": "Type",
              "de": "Typ"
            },
            "values": [
              {
                "id": "any",
                "label": {
                  "en": "Any",
                  "de": "Alle"
                }
              },
              {
                "id": "Movie",
                "label": {
                  "en": "Movie",
                  "de": "Film"
