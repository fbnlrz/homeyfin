{
  "name": { "en": "Jellyfin User", "de": "Jellyfin-Benutzer" },
  "class": "tv",
  "capabilities": [
    "speaker_playing",
    "speaker_next",
    "speaker_prev",
    "speaker_track",
    "speaker_artist",
    "speaker_album",
    "volume_set",
    "volume_mute",
    "media_title",
    "media_subtitle",
    "media_position",
    "media_duration",
    "client_online",
    "is_transcoding",
    "unwatched_count",
    "continue_watching_title"
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/user/assets/images/small.png",
    "large": "/drivers/user/assets/images/large.png",
    "xlarge": "/drivers/user/assets/images/xlarge.png"
  },
  "pair": [
    { "id": "select_server" }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Behavior", "de": "Verhalten" },
      "children": [
        {
          "id": "stoppedDebounceMs",
          "type": "number",
          "label": { "en": "Stop debounce (ms)", "de": "Stop-Entprellzeit (ms)" },
          "hint": {
            "en": "Wait this long after the user's session disappears before firing the Stopped trigger.",
            "de": "So lange warten, nachdem die Session verschwindet, bevor der Stop-Trigger feuert."
          },
          "value": 4000,
          "min": 0,
          "max": 30000
        },
        {
          "id": "unwatchedRefreshMinutes",
          "type": "number",
          "label": { "en": "Unwatched refresh (min)", "de": "Refresh ungesehen (min)" },
          "value": 10,
          "min": 1,
          "max": 120
        }
      ]
    }
  ]
}
