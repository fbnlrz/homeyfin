{
  "name": { "en": "Jellyfin Server", "de": "Jellyfin-Server" },
  "class": "other",
  "capabilities": [
    "library_movies_count",
    "library_series_count",
    "library_episodes_count",
    "last_added_title",
    "scan_in_progress"
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/server/assets/images/small.png",
    "large": "/drivers/server/assets/images/large.png",
    "xlarge": "/drivers/server/assets/images/xlarge.png"
  },
  "pair": [
    { "id": "credentials", "navigation": { "next": "select_user" } },
    { "id": "select_user" }
  ],
  "repair": [
    { "id": "credentials", "navigation": { "next": "select_user" } },
    { "id": "select_user" }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Connection", "de": "Verbindung" },
      "children": [
        {
          "id": "baseUrl",
          "type": "text",
          "label": { "en": "Server URL", "de": "Server-URL" },
          "hint": { "en": "e.g. http://192.168.1.10:8096", "de": "z. B. http://192.168.1.10:8096" },
          "value": ""
        },
        {
          "id": "apiKey",
          "type": "password",
          "label": { "en": "API Key", "de": "API-Schlüssel" },
          "value": ""
        },
        {
          "id": "userName",
          "type": "text",
          "label": { "en": "Default user", "de": "Standard-Benutzer" },
          "hint": {
            "en": "User whose latest items / counts are reported.",
            "de": "Benutzer, dessen 'Zuletzt hinzugefügt' und Counts angezeigt werden."
          },
          "value": ""
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Polling", "de": "Polling" },
      "children": [
        {
          "id": "libraryPollMinutes",
          "type": "number",
          "label": { "en": "Library refresh (min)", "de": "Bibliotheks-Refresh (min)" },
          "value": 5,
          "min": 1,
          "max": 120
        },
        {
          "id": "fallbackPollSeconds",
          "type": "number",
          "label": { "en": "Session fallback poll (s)", "de": "Session-Fallback-Polling (s)" },
          "hint": {
            "en": "How often to poll /Sessions when the WebSocket is disconnected.",
            "de": "Wie oft /Sessions abgefragt werden, wenn die WebSocket-Verbindung weg ist."
          },
          "value": 30,
          "min": 5,
          "max": 300
        }
      ]
    }
  ]
}
