{
  "name": "com.frlrnzn.homeyfin",
  "version": "0.1.0",
  "description": "Jellyfin integration for Homey",
  "main": "app.js",
  "scripts": {
    "build:manifest": "node scripts/build-app-json.mjs",
    "build:assets": "node scripts/build-assets.mjs",
    "build": "npm run build:manifest && tsc",
    "test": "tsc -p tsconfig.test.json && node --import tsx --test test/*.test.ts",
    "validate": "npm run build:manifest && homey app validate",
    "run": "npm run build:manifest && homey app run",
    "install:app": "npm run build:manifest && homey app install"
  },
  "dependencies": {
    "source-map-support": "^0.5.21",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.7",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
